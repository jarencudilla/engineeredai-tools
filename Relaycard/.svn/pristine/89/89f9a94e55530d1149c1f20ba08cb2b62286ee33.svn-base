<?php
/**
 * attribution.php
 *
 * Renders the RelayCard attribution line.
 * Locked on free tier — cannot be removed without premium.
 * Dofollow by design — brand + SEO play for engineeredai.net.
 *
 * @package RelayCard
 */

if ( ! defined( 'ABSPATH' ) ) exit;

/**
 * relaycard_attribution
 * Returns attribution HTML string.
 *
 * @return string
 */
function relaycard_attribution() {
    return '<div class="relaycard-attribution"><a href="https://engineeredai.net" target="_blank" rel="noopener">// built with RelayCard &mdash; engineeredai.net</a></div>';
}
